{
  "name": "teachly",
  "version": "1.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "teachly",
      "version": "1.0.0",
      "license": "ISC",
      "workspaces": [
        "apps/frontend",
        "apps/backend",
        "packages/shared"
      ]
    },
    "apps/backend": {
      "name": "@teachly/backend",
      "version": "1.0.0",
      "license": "ISC",
      "dependencies": {
        "@teachly/shared": "*"
      }
    },
    "apps/frontend": {
      "name": "@teachly/frontend",
      "version": "1.0.0",
      "license": "ISC",
      "dependencies": {
        "@teachly/shared": "*"
      }
    },
    "node_modules/@teachly/backend": {
      "resolved": "apps/backend",
      "link": true
    },
    "node_modules/@teachly/frontend": {
      "resolved": "apps/frontend",
      "link": true
    },
    "node_modules/@teachly/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "packages/shared": {
      "name": "@teachly/shared",
      "version": "1.0.0",
      "license": "ISC"
    }
  }
}
